{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "demo",
  "compatibility_date": "2026-06-14",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "routes": [
    { "pattern": "demo.eno.solutions/*", "zone_name": "eno.solutions" }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
